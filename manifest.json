{
  "$schema": "https://api.kittl.com/extensions/manifest/schema.json",
  "displayName": "Dropbox",
  "icon": "icon-dropbox.svg",
  "tagline": "Browse and add your Dropbox files to Kittl.",
  "installPage": {
    "description": "Connect your Dropbox account to browse and add images directly to your Kittl canvas.",
    "coverImage": "icon-dropbox.svg",
    "termsAndConditionsLink": "https://www.kittl.com/terms",
    "privacyPolicyLink": "https://www.kittl.com/privacy"
  },
  "config": {
    "scopes": [
      "design:state:read",
      "design:state:write"
    ],
    "embed": {
      "mainAppPanel": {
        "path": "index.html"
      }
    },
    "oauthProviders": {
      "dropbox": {
        "clientId": "qkcenabcj9he44a",
        "scope": "files.metadata.read files.content.read files.content.write account_info.read",
        "authorizationUrl": "https://www.dropbox.com/oauth2/authorize",
        "accessType": "offline",
        "tokenUrl": "https://api.dropboxapi.com/oauth2/token"
      }
    }
  }
}
